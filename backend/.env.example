OPENAI_API_KEY=replace_with_api_key

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64

FAISS_INDEX_PATH=local_indexes/policy_faiss

RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.0

HYBRID_VECTOR_CANDIDATE_K=20
HYBRID_KEYWORD_CANDIDATE_K=20
KEYWORD_MINIMUM_SCORE=0.0

HYBRID_RRF_CONSTANT=60
HYBRID_VECTOR_WEIGHT=1.0
HYBRID_KEYWORD_WEIGHT=1.0

RERANKER_BACKEND=sentence_transformers
RERANKER_CANDIDATE_K=10
RERANKER_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_DEVICE=cpu

CONTEXT_MAX_TOKENS=3000
CONTEXT_MAX_CHUNKS=5
ANSWER_MAX_TOKENS=700
CONTEXT_TOKEN_ENCODING=cl100k_base
MINIMUM_EVIDENCE_CHUNKS=1

GENERATION_MODEL=gpt-4.1-mini
GENERATION_TEMPERATURE=0
GENERATION_TIMEOUT_SECONDS=60
GENERATION_MAX_RETRIES=2
GENERATION_USE_RESPONSES_API=true

# Production model-gateway example:
# OPENAI_BASE_URL=https://approved-model-gateway.example.com/v1