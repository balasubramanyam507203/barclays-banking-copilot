# Generated .env.docker should be created with:
# python scripts/prepare_docker_env.py
#
# Do not put a raw PostgreSQL password in this file.
# POSTGRES_PASSWORD_URL is URL-encoded by the preparation script.

POSTGRES_DB=policy_copilot
POSTGRES_USER=policy_copilot
POSTGRES_PASSWORD_URL=CHANGE_ME
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
BUILD_INDEX_ON_STARTUP=true
FORCE_REBUILD_INDEX=false
